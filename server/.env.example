# Authentication
# Generate secure random strings (e.g. using `openssl rand -hex 32`)
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Client URL (for CORS)
# Set to your Firebase Hosting URL in production
CLIENT_URL=https://your-project.web.app

# Azure OpenAI Configuration
# Format: https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Format: Your API key from the Azure portal
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Format: YYYY-MM-DD or YYYY-MM-DD-preview
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Format: The deployment name of your model in Azure AI Studio
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
