# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Database
# Format: mongodb://<host>:<port>/<database_name> or mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database_name>
MONGODB_URI=mongodb://localhost:27017/skill_assessment

# Authentication
# Format: Generate a secure random string (e.g. using `openssl rand -hex 32`)
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Client URL (for CORS)
# Format: The full URL of your frontend application
CLIENT_URL=http://localhost:5173

# Azure OpenAI Configuration
# Format: https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Format: A 32-character alphanumeric key from your Azure portal
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Format: YYYY-MM-DD or YYYY-MM-DD-preview (e.g. 2025-01-01-preview)
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Format: The deployment name of your model in Azure AI Studio
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
